# Helmsman ローカル開発用 環境変数テンプレート
# .env にコピーして値を埋めてください。本番デプロイでは Container Apps の secret として注入されます。

# ===== Azure OpenAI =====
AZURE_OPENAI_ENDPOINT=https://aoai-helmsman-dev.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_HIGH=gpt-5.4
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-5.4-mini
AZURE_OPENAI_DEPLOYMENT_REALTIME=gpt-realtime-1.5
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-small

# ===== Cosmos DB =====
COSMOS_ENDPOINT=https://helmsman-dev-cosmos.documents.azure.com:443/
COSMOS_KEY=<your-key>
COSMOS_DATABASE=helmsman

# ===== Azure AI Speech (Teams bot STT/TTS) =====
AZURE_SPEECH_KEY=<your-key>
AZURE_SPEECH_REGION=westus2

# ===== Azure AI Search (文書 RAG) =====
AZURE_SEARCH_ENDPOINT=https://helmsman-dev-search-xxxxx.search.windows.net
AZURE_SEARCH_KEY=<your-key>
AZURE_SEARCH_INDEX_NAME=helmsman-documents

# ===== Azure AI Document Intelligence =====
AZURE_DOCINTEL_ENDPOINT=https://helmsman-dev-docintel.cognitiveservices.azure.com/
AZURE_DOCINTEL_KEY=<your-key>

# ===== Azure Storage (Blob for uploaded documents) =====
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# ===== Azure Communication Services (Teams Bot) =====
ACS_CONNECTION_STRING=endpoint=https://helmsman-dev-acs.communication.azure.com/;accesskey=<key>
# Container App から見た自分の public FQDN (ACS webhook + WebSocket の宛先)
ACS_CALLBACK_BASE_URL=https://helmsman-dev-api.ashyocean-e634ae12.westus2.azurecontainerapps.io

# ===== Observability (optional) =====
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=https://...
LOG_LEVEL=INFO

# ===== API 認証 (optional dev) =====
# HELMSMAN_API_KEY=<shared-secret>
# HELMSMAN_REQUIRE_AUTH=false

# ===== Microsoft Teams Bot (Graph Calling, Service-hosted) =====
# Entra ID で `az ad app create --display-name "helmsman-bot" --sign-in-audience AzureADMyOrg`
# クライアントシークレットは `az ad app credential reset` で発行
# Application Access Policy (PowerShell New-CsApplicationAccessPolicy) で organizer user に grant 必須
MICROSOFT_APP_TYPE=SingleTenant
MICROSOFT_APP_ID=<bot-app-id-guid>
MICROSOFT_APP_PASSWORD=<bot-client-secret>
MICROSOFT_APP_TENANT_ID=<tenant-id-guid>
MICROSOFT_APP_DISPLAY_NAME=helmsman-bot
# Application permission で /users/{id}/onlineMeetings を引く時の organizer ユーザー
MICROSOFT_APP_ORGANIZER_USER_ID=<organizer-user-object-id>
GRAPH_CALLBACK_PATH=/api/calling

# ===== Environment =====
ENVIRONMENT=dev
