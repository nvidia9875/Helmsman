    "cosmosAccountName": "[format('{0}-cosmos', variables('namePrefix'))]",
    "signalRName": "[format('{0}-signalr', variables('namePrefix'))]",
    "keyVaultName": "[take(format('{0}-kv-{1}', variables('namePrefix'), parameters('resourceSuffix')), 24)]",
    "logAnalyticsName": "[format('{0}-log', variables('namePrefix'))]",
    "appInsightsName": "[format('{0}-ai', variables('namePrefix'))]",
    "containerAppsEnvName": "[format('{0}-cae', variables('namePrefix'))]",
    "containerAppName": "[format('{0}-api', variables('namePrefix'))]",
    "speechName": "[format('{0}-speech', variables('namePrefix'))]"
  },
