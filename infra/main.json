        "description": "既存の Azure OpenAI リソース名 (CLI で別途作成済み)"
      }
    },
    "appImage": {
      "type": "string",
      "defaultValue": "mcr.microsoft.com/k8se/quickstart:latest",
      "metadata": {
        "description": "Container Apps に注入するアプリ イメージ (初回は hello world)"
      }
