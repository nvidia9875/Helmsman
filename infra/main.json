    "resourceSuffix": {
      "type": "string",
      "defaultValue": "[uniqueString(resourceGroup().id)]",
      "metadata": {
        "description": "リソース命名の suffix（ユニーク性確保用）"
      }
    }
  },
  "variables": {
    "namePrefix": "[format('{0}-{1}', parameters('projectName'), parameters('env'))]",
